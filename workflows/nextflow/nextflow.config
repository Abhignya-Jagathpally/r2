/**
 * Nextflow configuration file for MM transcriptomics pipeline
 * Supports local, SLURM, Docker, and Singularity execution
 */

manifest {
    name = 'MM Transcriptomics Risk Signature Pipeline'
    author = 'PhD Researcher 1'
    homePage = 'https://github.com/institution/mm-transcriptomics'
    description = 'Bulk transcriptomics cross-study MM risk-signature pipeline'
    mainScript = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version = '0.1.0'
}

// ============================================================================
// DEFAULT PARAMETERS
// ============================================================================

params {
    // Input/Output
    input_dir = "${launchDir}/data/raw"
    output_dir = "${launchDir}/outputs"
    config_file = "${launchDir}/config/pipeline_config.yaml"

    // Data parameters
    datasets = ["GSE2658", "GSE19784", "GSE39754", "CoMMpass"]
    exclude_datasets = []

    // Preprocessing
    normalize_method = "quantile"
    low_expr_threshold = 1.0
    batch_correction = true

    // Pathway analysis
    pathway_databases = ["Hallmark", "KEGG", "Reactome", "curated_MM"]
    pathway_methods = ["GSVA", "ssGSEA"]
    n_pathway_features = 500

    // Modeling
    train_baselines = true
    train_modern = true
    train_fusion = true

    // Evaluation
    n_outer_folds = 5
    n_inner_folds = 3
    test_size = 0.2
    random_seed = 42

    // MLflow
    mlflow_uri = "http://localhost:5000"
    mlflow_experiment = "mm_risk_signature_v1"

    // Compute
    cpus = 4
    memory = "16.GB"
    time = "12.h"

    // Flags
    help = false
    version = false
}

// ============================================================================
// PROFILES: Local, SLURM, Docker, Singularity
// ============================================================================

profiles {
    // Local execution
    local {
        process {
            executor = 'local'
            cpus = { params.cpus }
            memory = { params.memory }
            time = { params.time }
        }
        executor {
            queueSize = 4
        }
    }

    // SLURM HPC
    slurm {
        process {
            executor = 'slurm'
            queue = 'gpu'  // Change to 'cpu' if no GPU needed
            cpus = { params.cpus }
            memory = { params.memory }
            time = { params.time }

            // Module loading
            beforeScript = '''
                module purge
                module load cuda/12.0
                module load gcc/11.3.0
                module load conda
                source activate mmpipeline
            '''

            // GPU resource allocation for SLURM
            clusterOptions = { "-N 1 --gpus-per-task=1" }
        }

        executor {
            queueSize = 100
            submitRateLimit = '10/1m'
        }
    }

    // Docker containerization
    docker {
        process {
            executor = 'local'
            container = 'mm-transcriptomics:latest'
            containerOptions = '-v ${PWD}:/workspace -w /workspace'
        }

        docker {
            enabled = true
            runOptions = '-u $(id -u):$(id -g)'
            registry = 'docker.io'
            fixOwnership = true
            runOptions = '-v /etc/passwd:/etc/passwd:ro -v /etc/group:/etc/group:ro'
        }
    }

    // Singularity/Apptainer
    singularity {
        process {
            executor = 'slurm'
            container = 'mmpipeline.sif'
            containerOptions = '--bind ${PWD}:/workspace'
        }

        singularity {
            enabled = true
            autoMounts = true
            cacheDir = "${launchDir}/.singularity"
            envWhitelist = 'CUDA_VISIBLE_DEVICES,TMPDIR'
        }

        executor {
            queueSize = 100
            submitRateLimit = '10/1m'
        }
    }

    // Development profile with verbose logging
    dev {
        process {
            executor = 'local'
            cpus = 2
            memory = '8.GB'
            time = '2.h'
            errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
            maxRetries = 2
        }

        executor {
            queueSize = 2
        }
    }

    // Testing profile
    test {
        process {
            executor = 'local'
            cpus = 1
            memory = '4.GB'
            time = '30.m'
        }

        params {
            datasets = ["GSE2658"]
            n_outer_folds = 2
            n_inner_folds = 2
        }
    }
}

// ============================================================================
// PROCESS-SPECIFIC CONFIGURATION
// ============================================================================

process {
    // Default process configuration
    errorStrategy = { task.exitStatus in [1,143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 1
    maxForks = 4

    // Process-specific settings
    withLabel: 'io' {
        cpus = 1
        memory = '8.GB'
        time = '1.h'
    }

    withLabel: 'preprocessing' {
        cpus = { params.cpus }
        memory = { params.memory }
        time = { params.time }
    }

    withLabel: 'pathway_analysis' {
        cpus = { params.cpus * 2 }
        memory = { params.memory * 1.5 }
        time = { params.time * 2 }
    }

    withLabel: 'modeling' {
        cpus = { params.cpus }
        memory = { params.memory * 2 }
        time = { params.time * 3 }
        containerOptions = '-v ${PWD}:/workspace --gpus all'
    }

    withLabel: 'evaluation' {
        cpus = { params.cpus }
        memory = { params.memory }
        time = { params.time }
    }

    withLabel: 'reporting' {
        cpus = 2
        memory = '8.GB'
        time = '30.m'
    }
}

// ============================================================================
// CONDA ENVIRONMENT
// ============================================================================

conda {
    cacheDir = "${launchDir}/.conda"
    useMamba = true
    useMicromamba = true
}

// ============================================================================
// REPORT GENERATION
// ============================================================================

report {
    enabled = true
    file = "${params.output_dir}/reports/nextflow_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.output_dir}/reports/timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output_dir}/reports/trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,process,tag,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt'
}

// ============================================================================
// WORKDIR & CLEANUP
// ============================================================================

workDir = "${launchDir}/work"

cleanup = false

// Enable caching to reuse intermediate results
cache = 'standard'

// ============================================================================
// WAVE & FUSION (for container management)
// ============================================================================

wave {
    enabled = false
}

fusion {
    enabled = false
}
